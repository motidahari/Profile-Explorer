{
  "name": "profiles-service",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "test": "npm run test:unit && npm run test:integration && npm run test:api",
    "test:unit": "bash ../../scripts/run-tests.sh --label backend:unit --bin jest --glob \"src/**/*.spec.ts\" --exclude .integration-spec.ts --exclude .e2e-spec.ts",
    "test:integration": "bash ../../scripts/run-tests.sh --label backend:integration --bin jest --glob \"src/**/*.integration-spec.ts\" --glob \"test/**/*.integration-spec.ts\"",
    "test:api": "bash ../../scripts/run-tests.sh --label backend:api --bin jest --glob \"test/**/*.e2e-spec.ts\"",
    "lint": "eslint \"src/**/*.ts\"",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^10.3.9",
    "@nestjs/config": "^3.2.2",
    "@nestjs/core": "^10.3.9",
    "@nestjs/platform-express": "^10.3.9",
    "@nestjs/typeorm": "^10.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "pg": "^8.12.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@nestjs/cli": "^10.3.2",
    "@nestjs/schematics": "^10.1.1",
    "@types/node": "^20.14.5",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^15.6.0",
    "prettier": "^3.3.2",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  }
}
