PORT=3000
CORS_ORIGIN=http://localhost:5173

# PostgreSQL (matches docker-compose.yml)
DB_HOST=localhost
DB_PORT=5432
DB_USER=profiles
DB_PASSWORD=profiles
DB_NAME=profiles
# Auto-create schema from entities. Dev only — use migrations in production.
DB_SYNCHRONIZE=true

# Random profile provider (GET /profiles/random)
RANDOMUSER_API_URL=https://randomuser.me/api
RANDOM_PROFILE_COUNT=10
