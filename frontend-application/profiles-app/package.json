{
  "name": "profiles-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --build && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --build --force",
    "test": "npm run test:unit && npm run test:page",
    "test:unit": "bash ../../scripts/run-tests.sh --label frontend:unit --bin vitest --glob \"src/**/*.spec.ts\" --exclude .page.spec.ts -- run",
    "test:page": "bash ../../scripts/run-tests.sh --label frontend:page --bin playwright --glob \"src/**/*.page.spec.ts\" --glob \"tests/**/*.page.spec.ts\" -- test",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,vue,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,scss,json}\""
  },
  "dependencies": {
    "axios": "^1.7.2",
    "pinia": "^2.1.7",
    "vue": "^3.4.29",
    "vue-i18n": "^9.13.1",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "@types/node": "^20.14.5",
    "@vitejs/plugin-vue": "^5.0.5",
    "@vue/tsconfig": "^0.5.1",
    "eslint": "^9.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^9.26.0",
    "prettier": "^3.3.2",
    "sass": "^1.77.6",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.3.1",
    "vue-tsc": "^2.0.21"
  }
}
